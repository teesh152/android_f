<?xml version="1.0" encoding="utf-8"?>
<!-- CUSTOM-DESIGNED UI ELEMENT (required):
     gradient background with rounded corners for the Watch button -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/red_dark" />
            <corners android:radius="26dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:startColor="@color/red_primary"
                android:endColor="@color/red_dark" />
            <corners android:radius="26dp" />
            <padding
                android:top="12dp"
                android:bottom="12dp"
                android:left="16dp"
                android:right="16dp" />
        </shape>
    </item>
</selector>
